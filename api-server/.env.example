GAS_ENV=development
DATABASE__DSN=postgres://vault:vault@localhost:5432/vault?sslmode=disable
DATABASE__DRIVER=pgx
STORAGE__REGION=us-east-1
STORAGE__BUCKET=vault-files
STORAGE__ENDPOINT=http://localhost:4566
STORAGE__ACCESS_KEY_ID=test
STORAGE__SECRET_ACCESS_KEY=test
QUEUE__REGION=us-east-1
QUEUE__ENDPOINT=http://localhost:4566
EMAIL__REGION=us-east-1
EMAIL__FROM=noreply@example.com
EMAIL__ENDPOINT=http://localhost:4566
CACHE__MAX_ENTRIES=1000
CACHE__DEFAULT_TTL=5m
JWT__SIGNING_KEY=dev-secret-change-me-in-production
JWT__ISSUER=file-vault
JWT__EXPIRY=24h
SHARE_NOTIFICATION_QUEUE=http://localhost:4566/000000000000/share-notifications
